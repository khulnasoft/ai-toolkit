{
  "name": "@ai-toolkit/ai-elements",
  "version": "0.0.1",
  "private": true,
  "description": "Universal AI components and elements for building AI interfaces",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js"
    },
    "./playground": {
      "types": "./dist/playground.d.ts",
      "import": "./dist/playground.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-toolkit/design-system": "workspace:*",
    "ai": "workspace:*",
    "@ai-sdk/react": "workspace:*",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
