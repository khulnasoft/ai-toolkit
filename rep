#!/usr/bin/env bash
set -euo pipefail

OLD="${1:-oldname}"
NEW="${2:-newname}"
DRY_RUN="${DRY_RUN:-false}"

log() {
  printf "[%s] %s\n" "$(date +'%H:%M:%S')" "$*"
}

run() {
  if [ "$DRY_RUN" = "true" ]; then
    echo "DRY-RUN: $*"
  else
    eval "$@"
  fi
}

# Detect sed flavor (GNU vs BSD)
if sed --version >/dev/null 2>&1; then
  SED_INPLACE=(-i)
else
  SED_INPLACE=(-i '')
fi

log "🔍 Replacing content: '$OLD' → '$NEW'"

# Replace content in files (skip binary)
rg -l -0 --fixed-strings --hidden --no-ignore -g '!*.git/*' "$OLD" \
| xargs -0 sed "${SED_INPLACE[@]}" "s|$OLD|$NEW|g"

log "📄 Content replacement done"

# Rename files (deepest first)
log "📁 Renaming files..."

find . -type f -name "*$OLD*" -print0 \
| sort -z -r \
| while IFS= read -r -d '' file; do
  newfile="${file//$OLD/$NEW}"
  if [ "$file" != "$newfile" ]; then
    run mv -v "\"$file\"" "\"$newfile\""
  fi
done

# Rename directories (deepest first)
log "📂 Renaming directories..."

find . -type d -name "*$OLD*" -print0 \
| sort -z -r \
| while IFS= read -r -d '' dir; do
  newdir="${dir//$OLD/$NEW}"
  if [ "$dir" != "$newdir" ]; then
    run mv -v "\"$dir\"" "\"$newdir\""
  fi
done

log "✅ Done!"